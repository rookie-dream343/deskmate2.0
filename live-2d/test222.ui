  <property name="styleSheet">
   <string notr="true">/* === Nintendo Pixel Style === */

QMainWindow {
	background-color: #F5F5EE;
}

QWidget#centralwidget {
	background-color: #F5F5EE;
}

QFrame#sidebar {
	background-color: #3C5A99;
	border: 3px solid #2A4073;
	border-radius: 4px;
}

QFrame#contentArea {
	background-color: #FFFFFF;
	border: 3px solid #CCCCCC;
	border-radius: 4px;
}

QStackedWidget {
	background-color: transparent;
}

QWidget#page, QWidget#page_2, QWidget#page_3, QWidget#page_4, QWidget#page_5, QWidget#page_6, QWidget#page_terminal, QWidget#page_voice_clone, QWidget#page_tutorial, QWidget#page_tools, QWidget#page_ui_settings, QWidget#page_cloud_config, QWidget#page_prompt_market {
	background-color: transparent;
}

QLabel {
	color: #2D2D2D;
	background-color: transparent;
}

QLineEdit {
	background-color: #FFFFFF;
	border: 2px solid #AAAAAA;
	border-radius: 3px;
	padding: 6px 9px;
	color: #2D2D2D;
}

QLineEdit:focus {
	border: 2px solid #3C5A99;
	background-color: #F0F4FF;
}

QTextEdit {
	background-color: #FFFFFF;
	border: 2px solid #AAAAAA;
	border-radius: 3px;
	padding: 15px;
	color: #2D2D2D;
}

QTextEdit:focus {
	border: 2px solid #3C5A99;
	background-color: #F0F4FF;
}

QCheckBox {
	color: #2D2D2D;
	spacing: 12px;
	background-color: transparent;
}

QCheckBox::indicator {
	width: 16px;
	height: 16px;
	border-radius: 2px;
	border: 2px solid #888888;
	background-color: #FFFFFF;
}

QCheckBox::indicator:checked {
	background-color: #E60012;
	border: 2px solid #B0000E;
}

QCheckBox::indicator:hover {
	border: 2px solid #3C5A99;
}

QPushButton {
	background-color: #F0F0E8;
	color: #2D2D2D;
	border: 2px solid #BBBBBB;
	border-radius: 4px;
	padding: 10px 20px;
}

QPushButton:hover {
	background-color: #E0E0D8;
	border: 2px solid #888888;
	color: #111111;
}

QPushButton:pressed {
	background-color: #D0D0C8;
	border: 2px solid #666666;
}

/* sidebar nav buttons */
QFrame#sidebar QPushButton {
	background-color: transparent;
	color: #FFFFFF;
	border: 2px solid transparent;
	border-radius: 4px;
	padding: 10px 15px;
	text-align: left;
}

QFrame#sidebar QPushButton:hover {
	background-color: #FFD700;
	color: #2D2D2D;
	border: 2px solid #E6C200;
}

QFrame#sidebar QPushButton:pressed {
	background-color: #E6C200;
	color: #2D2D2D;
}

#pushButton_toggle_live2d[state="start"],#pushButton_start_terminal,#pushButton_start_asr,#pushButton_start_bert,#pushButton_start_rag,#pushButton_start_minecraft_terminal {
	background-color: #43B047;
	color: #FFFFFF;
	border: 2px solid #2E8B32;
}

#pushButton_toggle_live2d[state="start"]:hover,#pushButton_start_terminal:hover,#pushButton_start_asr:hover,#pushButton_start_bert:hover,#pushButton_start_rag:hover,#pushButton_start_minecraft_terminal:hover {
	background-color: #3A9E3E;
}

#pushButton_toggle_live2d[state="stop"],#pushButton_stop_terminal,#pushButton_stop_asr,#pushButton_stop_bert,#pushButton_stop_rag {
	background-color: #E04040;
	color: #FFFFFF;
	border: 2px solid #B83030;
}

#pushButton_toggle_live2d[state="stop"]:hover,#pushButton_stop_terminal:hover,#pushButton_stop_asr:hover,#pushButton_stop_bert:hover,#pushButton_stop_rag:hover {
	background-color: #CC3636;
}

#pushButton_select_model,#pushButton_select_audio {
	background-color: #E8F4FD;
	border: 2px dashed #5B9BD5;
	border-radius: 4px;
	color: #3C5A99;
	text-align: center;
}

#pushButton_select_model:hover,#pushButton_select_audio:hover {
	background-color: #D0E8F8;
	border: 2px dashed #3C5A99;
	color: #2A4073;
}

#pushButton_select_model:pressed,#pushButton_select_audio:pressed {
	background-color: #B8DCF0;
}

#start_singing_btn,#stop_singing_btn {
	background-color: #5B9BD5;
	color: #FFFFFF;
	border: 2px solid #4178B0;
	padding: 12px 20px;
	margin: 5px;
}

#start_singing_btn:hover,#stop_singing_btn:hover {
	background-color: #4A8BC4;
}

QPushButton#saveConfigButton {
	background-color: #4A6FA5;
	color: #FFFFFF;
	border: 2px solid #3A5A88;
	border-radius: 4px;
}

QPushButton#saveConfigButton:hover {
	background-color: #3D5F90;
}

QPushButton#pushButton_tutorial {
	background-color: #FF8C00;
	color: #FFFFFF;
	border: 2px solid #CC7000;
	border-radius: 4px;
}

QPushButton#pushButton_tutorial:hover {
	background-color: #E67E00;
	border: 2px solid #B36200;
}

QComboBox {
	background-color: #FFFFFF;
	border: 2px solid #AAAAAA;
	border-radius: 3px;
	padding: 6px 9px;
	color: #2D2D2D;
}

QComboBox:focus {
	border: 2px solid #3C5A99;
}

QComboBox::drop-down {
	subcontrol-origin: padding;
	subcontrol-position: top right;
	width: 30px;
	border-left: 2px solid #AAAAAA;
	border-top-right-radius: 3px;
	border-bottom-right-radius: 3px;
	background-color: #F0F0E8;
}

QComboBox::down-arrow {
	width: 12px;
	height: 12px;
	image: none;
	border: 2px solid #2D2D2D;
	border-top: none;
	border-right: none;
	transform: rotate(-45deg);
	margin: 5px;
}

QComboBox QAbstractItemView {
	background-color: #FFFFFF;
	border: 2px solid #AAAAAA;
	border-radius: 3px;
	selection-background-color: #FFD700;
	selection-color: #2D2D2D;
	color: #2D2D2D;
	padding: 5px;
}

QTabWidget::pane {
	border: 2px solid #CCCCCC;
	border-radius: 3px;
	background: transparent;
	margin-top: 5px;
}

QTabBar::tab {
	background-color: #F0F0E8;
	color: #2D2D2D;
	border: 2px solid #CCCCCC;
	border-bottom: none;
	border-top-left-radius: 4px;
	border-top-right-radius: 4px;
	padding: 10px 30px;
	margin-right: 3px;
}

QTabBar::tab:selected {
	background-color: #FFFFFF;
	color: #E60012;
	border: 2px solid #3C5A99;
	border-bottom: 2px solid #FFFFFF;
	font-weight: bold;
}

QTabBar::tab:hover {
	background-color: #FFD700;
	color: #2D2D2D;
	border: 2px solid #E6C200;
	border-bottom: none;
}

QScrollBar:vertical {
	background-color: #EEEEEE;
	width: 10px;
	border-radius: 2px;
}

QScrollBar::handle:vertical {
	background-color: #C0C0C0;
	border-radius: 2px;
	min-height: 20px;
}

QScrollBar::handle:vertical:hover {
	background-color: #A0A0A0;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
	height: 0px;
}

QLabel#sectionTitle {
	color: #3C5A99;
	background-color: transparent;
	font-weight: bold;
}

QMenuBar {
	background-color: #3C5A99;
	color: #FFFFFF;
}

QMenuBar::item:selected {
	background-color: #FFD700;
	color: #2D2D2D;
}

QStatusBar {
	background-color: #3C5A99;
	color: #FFFFFF;
}

QFrame#control_panel_frame {
	background-color: #F8F8F2;
	border: 2px solid #CCCCCC;
	border-radius: 4px;
}

QTabWidget#tabWidget_logs::pane {
	border: 2px solid #CCCCCC;
	border-radius: 3px;
	background: transparent;
	margin-top: 5px;
}

QTabWidget#tabWidget_logs QTabBar::tab {
	background-color: #F0F0E8;
	color: #2D2D2D;
	border: 2px solid #CCCCCC;
	border-bottom: none;
	border-top-left-radius: 4px;
	border-top-right-radius: 4px;
	padding: 8px 15px;
	margin-right: 2px;
}

QTabWidget#tabWidget_logs QTabBar {
	qproperty-expanding: true;
}

QTabWidget#tabWidget_logs QTabBar::tab:selected {
	background-color: #FFFFFF;
	color: #E60012;
	border: 2px solid #3C5A99;
	border-bottom: 2px solid #FFFFFF;
	font-weight: bold;
}

QWidget#page_tools {
	background-color: transparent;
	border-radius: 4px;
}

QLabel#label_tools_title {
	color: #FFFFFF;
	font-size: 18px;
	font-weight: bold;
	background-color: #3C5A99;
	border: 2px solid #2A4073;
	border-radius: 4px;
	padding: 12px;
	margin: 10px 20px;
}

QScrollArea#scrollArea_tools {
	background: transparent;
	border: none;
	border-radius: 3px;
}

QListWidget#listWidget_tools {
	background-color: #FFFFFF;
	border: 2px solid #CCCCCC;
	border-radius: 4px;
	padding: 8px;
	font-size: 18px;
	selection-background-color: #FFD700;
}

QListWidget#listWidget_tools::item {
	background-color: #F8F8F2;
	border: 2px solid #DDDDDD;
	border-radius: 3px;
	padding: 12px 16px;
	margin: 4px 2px;
	color: #2D2D2D;
}

QListWidget#listWidget_tools::item:hover {
	background-color: #FFF8DC;
	border: 2px solid #FFD700;
	color: #2D2D2D;
}

QListWidget#listWidget_tools::item:selected {
	background-color: #FFD700;
	border: 2px solid #E6C200;
	color: #2D2D2D;
}

QListWidget#listWidget_tools::item[text^="● "] {
	color: #2D2D2D;
}

QListWidget#listWidget_tools::item[text^="● "]:first-letter {
	color: #43B047;
}

QListWidget#listWidget_tools::item[text^="○ "] {
	color: #2D2D2D;
}

QListWidget#listWidget_tools::item[text^="○ "]:first-letter {
	color: #AAAAAA;
}

QListWidget#listWidget_mcp_tools {
	background-color: #FFFFFF;
	border: 2px solid #CCCCCC;
	border-radius: 4px;
	padding: 8px;
	font-size: 18px;
	selection-background-color: #FFD700;
}

QListWidget#listWidget_mcp_tools::item {
	background-color: #F8F8F2;
	border: 2px solid #DDDDDD;
	border-radius: 3px;
	padding: 12px 16px;
	margin: 4px 2px;
	color: #2D2D2D;
}

QListWidget#listWidget_mcp_tools::item:hover {
	background-color: #FFF8DC;
	border: 2px solid #FFD700;
	color: #2D2D2D;
}

QListWidget#listWidget_mcp_tools::item:selected {
	background-color: #FFD700;
	border: 2px solid #E6C200;
	color: #2D2D2D;
}

QListWidget#listWidget_mcp_tools::item[text^="● "] {
	color: #2D2D2D;
}

QListWidget#listWidget_mcp_tools::item[text^="● "]:first-letter {
	color: #43B047;
}

QListWidget#listWidget_mcp_tools::item[text^="○ "] {
	color: #2D2D2D;
}

QListWidget#listWidget_mcp_tools::item[text^="○ "]:first-letter {
	color: #AAAAAA;
}

QTabWidget#tabWidget_tools {
	background: transparent;
}

QTabWidget#tabWidget_tools::pane {
	border: 2px solid #CCCCCC;
	border-radius: 3px;
	background: transparent;
	margin-top: 5px;
}

QTabWidget#tabWidget_tools QTabBar::tab {
	background-color: #F0F0E8;
	color: #2D2D2D;
	border: 2px solid #CCCCCC;
	border-bottom: none;
	border-top-left-radius: 4px;
	border-top-right-radius: 4px;
	padding: 12px 35px;
	margin: 0px 1px;
	font-family: 微软雅黑;
	font-size: 16px;
	min-width: 120px;
}

QTabWidget#tabWidget_tools QTabBar::tab:selected {
	background-color: #FFFFFF;
	color: #E60012;
	border: 2px solid #3C5A99;
	border-bottom: 2px solid #FFFFFF;
	font-weight: bold;
}

QTabWidget#tabWidget_tools QTabBar::tab:hover {
	background-color: #FFD700;
	color: #2D2D2D;
	border: 2px solid #E6C200;
	border-bottom: none;
}

QTabWidget#tabWidget_tools QTabBar {
	qproperty-expanding: true;
}</string>
